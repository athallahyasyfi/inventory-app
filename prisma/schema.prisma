// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tabel User (untuk login) ──────────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   // disimpan dalam bentuk hash (bcrypt)
  role      String   @default("staff") // "admin" atau "staff"
  createdAt DateTime @default(now())

  transactions StockTransaction[] // relasi: 1 user bisa punya banyak transaksi
}

// ── Tabel Kategori Produk ─────────────────────────────────────────────────────
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[] // relasi: 1 kategori bisa punya banyak produk
}

// ── Tabel Produk ──────────────────────────────────────────────────────────────
model Product {
  id         Int      @id @default(autoincrement())
  sku        String   @unique  // kode unik produk, misal "PRD-001"
  name       String
  price      Float
  stock      Int      @default(0)
  minStock   Int      @default(5)  // batas minimum stok sebelum alert
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  transactions StockTransaction[] // relasi: 1 produk bisa punya banyak transaksi
}

// ── Tabel Mutasi Stok ─────────────────────────────────────────────────────────
model StockTransaction {
  id        Int      @id @default(autoincrement())
  type      String   // "in" = masuk, "out" = keluar
  quantity  Int
  note      String?  // opsional, boleh kosong
  createdAt DateTime @default(now())

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId    Int
  user      User    @relation(fields: [userId], references: [id])
}
